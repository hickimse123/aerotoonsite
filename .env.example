# ══════════════════════════════════════════════════════════════════════════
# Aerotoon — Ortam Değişkenleri Şablonu
# ══════════════════════════════════════════════════════════════════════════
# Bu dosyayı ".env.local" olarak kopyala ve gerçek değerlerini gir.
# Vercel'de deploy ederken bu değerleri Project Settings → Environment
# Variables kısmına tek tek eklemen gerekiyor (bkz. DEPLOYMENT.md).
# ══════════════════════════════════════════════════════════════════════════

# ── Turso (veritabanı) ───────────────────────────────────────────────────
# https://turso.tech üzerinden ücretsiz alınır. DEPLOYMENT.md'deki adımları izle.
TURSO_DATABASE_URL=libsql://SENIN-DB-ADIN.turso.io
TURSO_AUTH_TOKEN=SENIN_TURSO_TOKEN_DEGERIN

# ── imgbb (görsel barındırma) ────────────────────────────────────────────
# https://api.imgbb.com/ adresinden ücretsiz alınır.
IMGBB_API_KEY=SENIN_IMGBB_API_KEY_DEGERIN

# ── Kimlik doğrulama ──────────────────────────────────────────────────────
# Rastgele, uzun ve tahmin edilemez bir metin olmalı. Üretmek için:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=BURAYA_UZUN_RASTGELE_BIR_ANAHTAR_YAZ

# ── Site adresi ───────────────────────────────────────────────────────────
# Vercel'de deploy ettikten sonra alacağın adres (SEO/sitemap için kullanılır)
NEXT_PUBLIC_BASE_URL=https://aerotoon.vercel.app

# ── Firebase Analytics (opsiyonel — sadece ziyaretçi istatistiği) ─────────
# Firebase Console → Project Settings → General → "Your apps" bölümünden alınır.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCbk_gmNH8WRoJM36Rls6G41GWKnoatEoo
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=aerotoon-site.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=aerotoon-site
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=aerotoon-site.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=828881953716
NEXT_PUBLIC_FIREBASE_APP_ID=1:828881953716:web:ac8f8dff65c3fc4ba7c8e1
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XT0YPVFHJY
